HELP.md
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
.vscode/

# Dependencies (Docker will install fresh with npm ci)
node_modules/

# Build output (Docker will build from source)
build/

# Environment files (injected at runtime, never baked into image)
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Tests
src/**/*.test.*
src/**/*.spec.*
